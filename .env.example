# ─── Hypixel API ────────────────────────────────────────────────────────────────
HYPIXEL_API_KEY=49f6d43d-71ee-404f-a424-403754f0a81c

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ─── Redis ──────────────────────────────────────────────────────────────────────
# Option A: Full URL (Upstash / cloud Redis) — takes priority if set
REDIS_URL=
# Option B: Manual connection (local Redis / Docker)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Set to true for Upstash (requires TLS)
REDIS_TLS=false

# ─── Rate Limiting ───────────────────────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX=100
# Window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (* for all)
CORS_ORIGINS=*

# ─── Request Timeout ────────────────────────────────────────────────────────────
# Milliseconds before upstream request is aborted
REQUEST_TIMEOUT_MS=10000

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
